# Shared styling for d2 architecture diagrams.
#
# Import at the very top of a diagram (path is relative to YOUR .d2 file):
#   ...@../assets/styles.d2
# then apply the classes below and render with:
#   python scripts/render.py your.d2 --preset default --title-pills
#
# This sets the elk layout + sensible padding and defines reusable classes:
#  - grouping boxes (group / subnet) styled as "titled boxes" that pair with
#    `render.py --title-pills`
#  - cloud-provider boundaries (aws / azure / gcp) in brand colors
#  - common component roles (service / datastore / queue / authz)
#
# Theme COLORS come from the render preset (--preset) or `--theme <id>`; to brand
# a built-in theme without a new file, add theme-overrides to your own vars, e.g.
#   vars: {d2-config: {theme-overrides: {B1: "#0B5FFF"}}}

vars: {
  d2-config: {
    layout-engine: elk
    pad: 40
  }
}

classes: {
  # --- Grouping containers (titled boxes; use with --title-pills) ---
  group: {
    label.near: top-left
    style: {fill: "#EDEFF5"; stroke: "#5B6B8C"; stroke-width: 2; bold: true; font-color: "#33415C"}
  }
  subnet: {
    label.near: top-left
    style: {fill: "#EDEFF5"; stroke: "#5B6B8C"; stroke-width: 2; stroke-dash: 3; bold: true; font-color: "#33415C"}
  }

  # --- Cloud provider boundaries (brand colors) ---
  aws: {
    label.near: top-left
    style: {fill: "#FFF7EC"; stroke: "#FF9900"; stroke-width: 2; bold: true; font-color: "#8A5A00"}
  }
  azure: {
    label.near: top-left
    style: {fill: "#EAF1FB"; stroke: "#0078D4"; stroke-width: 2; bold: true; font-color: "#10437A"}
  }
  gcp: {
    label.near: top-left
    style: {fill: "#E9F0FE"; stroke: "#1A73E8"; stroke-width: 2; bold: true; font-color: "#174EA6"}
  }

  # --- Component roles ---
  service: {style: {fill: "#E6F4EA"; stroke: "#34A853"}}
  datastore: {shape: cylinder; style: {fill: "#FCE8E6"; stroke: "#EA4335"}}
  queue: {shape: queue; style: {fill: "#FEF7E0"; stroke: "#FBBC04"}}
  authz: {shape: hexagon; style: {fill: "#FFF4CE"; stroke: "#C19C00"; bold: true}}
}
