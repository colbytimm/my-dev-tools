# Shared styling for d2 architecture diagrams.
#
# Import at the very top of a diagram (path is relative to YOUR .d2 file):
#   ...@../assets/styles.d2
# then apply the classes below and render with:
#   python scripts/render.py your.d2 --preset default --title-pills
#
# This sets the elk layout + sensible padding and defines reusable classes:
#  - grouping boxes (group / subnet) styled as "titled boxes" that pair with
#    `render.py --title-pills`
#  - cloud-provider boundaries (aws / azure / gcp) in brand colors
#  - common component roles (service / datastore / queue / authz)
#
# Theme COLORS come from the render preset (--preset) or `--theme <id>`; to brand
# a built-in theme without a new file, add theme-overrides to your own vars, e.g.
#   vars: {d2-config: {theme-overrides: {B1: "#0B5FFF"}}}

vars: {
  d2-config: {
    layout-engine: elk
    pad: 40
  }
}

classes: {
  # --- Grouping containers (titled boxes; use with --title-pills) ---
  # An explicit font-size keeps every group title the same size; without it d2
  # auto-scales container labels by nesting depth (outer bigger than inner).
  group: {
    label.near: top-left
    style: {fill: "#EDEFF5"; stroke: "#5B6B8C"; stroke-width: 2; bold: true; font-color: "#33415C"; font-size: 20}
  }
  subnet: {
    label.near: top-left
    style: {fill: "#EDEFF5"; stroke: "#5B6B8C"; stroke-width: 2; stroke-dash: 3; bold: true; font-color: "#33415C"; font-size: 20}
  }

  # --- Cloud provider boundaries (brand colors) ---
  aws: {
    label.near: top-left
    style: {fill: "#FFF7EC"; stroke: "#FF9900"; stroke-width: 2; bold: true; font-color: "#8A5A00"; font-size: 20}
  }
  azure: {
    label.near: top-left
    style: {fill: "#EAF1FB"; stroke: "#0078D4"; stroke-width: 2; bold: true; font-color: "#10437A"; font-size: 20}
  }
  gcp: {
    label.near: top-left
    style: {fill: "#E9F0FE"; stroke: "#1A73E8"; stroke-width: 2; bold: true; font-color: "#174EA6"; font-size: 20}
  }

  # --- Component roles ---
  service: {style: {fill: "#E6F4EA"; stroke: "#34A853"}}
  datastore: {shape: cylinder; style: {fill: "#FCE8E6"; stroke: "#EA4335"}}
  queue: {shape: queue; style: {fill: "#FEF7E0"; stroke: "#FBBC04"}}
  authz: {shape: hexagon; style: {fill: "#FFF4CE"; stroke: "#C19C00"; bold: true}}
}

# ============================================================================
# Branded palettes (ready-to-paste). d2 can't load a custom theme file, but you
# can recolor any built-in theme's palette slots. Pair with a clean base theme,
# e.g. `--preset default` / `--theme 0`. Slots: N1 (darkest text) -> N7 (canvas);
# B1 (darkest primary) -> B6 (lightest fill); AA*/AB* are accents.
#
# Copy ONE block into your diagram's own vars (not here, so it stays opt-in):
#
#   vars: {
#     d2-config: {
#       theme-overrides: { ...paste a palette below... }
#     }
#   }
#
# --- Corporate Blue ---------------------------------------------------------
#   N1: "#0A1F44"; N7: "#FFFFFF"
#   B1: "#0B3D91"; B2: "#1457B0"; B3: "#2E72CC"; B4: "#6FA3E0"; B5: "#B7D2F2"; B6: "#EAF2FC"
#   AA2: "#0F766E"; AA4: "#5EB1A8"; AA5: "#C5E8E3"; AB4: "#B0792E"; AB5: "#EAD7B7"
#
# --- Slate / Graphite (neutral, professional) -------------------------------
#   N1: "#1A2024"; N7: "#FFFFFF"
#   B1: "#334155"; B2: "#475569"; B3: "#64748B"; B4: "#94A3B8"; B5: "#CBD5E1"; B6: "#EEF2F6"
#   AA2: "#0E7490"; AA4: "#5FAEC4"; AA5: "#CDE8F0"; AB4: "#9A6B2F"; AB5: "#E6D5BA"
#
# --- Forest Green -----------------------------------------------------------
#   N1: "#14241B"; N7: "#FFFFFF"
#   B1: "#14532D"; B2: "#166534"; B3: "#2E7D44"; B4: "#6DAE84"; B5: "#B7DCC4"; B6: "#E9F5EE"
#   AA2: "#92400E"; AA4: "#C98A4B"; AA5: "#EBD3B5"; AB4: "#1E5E8A"; AB5: "#BBD6EA"
# ============================================================================
